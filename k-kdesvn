  .command("pocount")
  .summary("Show stats of the current folder with pocount.")
  .action(async () => {
    await $({
      nothrow: true,
      verbose: true,
    })`fd -L -e po -X pocount | grep TOTAL -A 8 | grep -v TOTAL`;
