The Git repository is only here locally, and is used for local diff checking.`);

/** Return team codes and names from the teamnames file as a record. */
function getTeamnames(): Record<string, string> {
  const path = [
    "trunk/l10n-kf6/teamnames",
    "kde-svn/trunk/l10n-kf6/teamnames",
  ].find((f) => existsSync(f));
  if (!path) throw new Error("Unable to read teamnames file!");
  const ret: Record<string, string> = {};
  for (const line of readFileSync(path, {
    encoding: "utf-8",
  }).split("\n")) {
    const trimmed = line.trim();
    if (trimmed.length === 0 || trimmed.startsWith("#")) continue;
    const [code, name] = trimmed.split("=") as [string, string];
    ret[code] = name;
  }
  return ret;
}

/**
 * Check out `languages` for the current repository.
 * Assumes current directory is the top level of the svn working copy.
 */
async function checkoutLanguages(languages: string[]) {
  // Valid team names. We read them here because they've only become
  // available here.
  const codesFromTeamnames = Object.keys(getTeamnames());
  const invalidLanguages = [
    ...new Set(languages).difference(new Set(codesFromTeamnames)),
  ];
  if (invalidLanguages.length > 0) {
    console.log(
      invalidLanguages.length === 1
        ? `Invalid language code provided: ${invalidLanguages}`
        : `Invalid language codes provided: ${invalidLanguages}`,
    );
    process.exit(1);
  }
  console.log(`Checking out language files...`);
  await $({
    verbose: true,
  })`svn update --quiet --set-depth infinity ${fastCartesian([
    ["trunk", "branches/stable"],
    ["l10n-kf5", "l10n-kf6"],
    languages,
  ])
    .map((a) => a.join("/"))
    .map((f) => escapeFile(f))}`;
}

/**
 * Checkout the KDE SVN repository to `dir` then set it up.
 * `readonly`: whether to clone from the readonly repo or not
 * `languages`: set the repository up for these languages
 * NOTE: This will manipulate cwd and cannot actually be run in parallel.
 */
async function setupSvnCheckout(
  dir: string,
  readonly: boolean | undefined,
  languages: string[],
) {
  const pwdBefore = process.cwd();
  const repoUrl = readonly
    ? "svn://anonsvn.kde.org/home/kde/"
    : "svn+ssh://svn@svn.kde.org/home/kde/";
  console.log(
    readonly
      ? `Checking out the read-only KDE subversion repository into ${dir}...`
      : `Checking out the read-write KDE subversion repository into ${dir}...`,
  );
  const $$ = $({ verbose: true });
  await $$`svn checkout --depth=empty ${repoUrl} ${escapeFile(dir)}`;
  cd(dir);
  // The goal:
  //   svn update --set-depth infinity branches/stable/l10n-kf{5,6}/{...}
  //   svn update --set-depth infinity trunk/l10n-kf{5,6}/{...}
  // but each parent directory needs to be a working copy, ie. checked out.
  // To checkout each parent directory, there are only 3 options:
  // - Set depth to infinity, which is too much
  // - Set depth to immediates, which includes irrelevant folders and files
  // - Set depth to files, which has irrelevant files but is the least bad
  // So this is setting the directory.
  console.log(`Setting up parent paths...`);
  await $$`svn update --set-depth files trunk`;
  await $$`svn update --set-depth files branches`;
  await $$`svn update --set-depth files branches/stable`;
  await $$`svn update --set-depth files ${
    // Doing the product in JS makes it easy to pass in variables
    fastCartesian([
      ["trunk", "branches/stable"],
      ["l10n-kf5", "l10n-kf6"],
    ])
      .map((a) => a.join("/"))
      .map((f) => escapeFile(f))
  }`;

  await checkoutLanguages(languages);

  console.log(`Setting up the local Git repository...`);
  await $$`git init`;
  console.log(`Excluding .svn from Git...`);
  mkdirSync(path.join(".git", "info"), { recursive: true });
  writeFileSync(path.join(".git", "info", "exclude"), `.svn/`);
  console.log(`Creating initial Git commit...`);
  await $$`git add .`;
  await $$`git commit -m before`;
  cd(pwdBefore);
}

/**
 * Set up symlinks for `lang`.
 * Assumes we are in the main dir.
 */
function setupLanguageSymlinks(lang: string) {
  const trunk = lang;
  const stable = `stable.${lang}`;
  mkdirSync(trunk, { recursive: true });
  mkdirSync(stable, { recursive: true });
  // kde-translations/{"","stable."}<lang>/{kf5,kf6}
  // We do {"","stable."}/<lang>/{kf5,kf6} because Lokalize finds files based
  // on the directory hierarchy, and we want to see kf5 and kf6 at once, but
  // we don't want to see trunk and stable at once. Trunk and stable should
  // instead be managed by opening one of them at a time, then using
  // alternative translations to automatically synchronize them over.
  for (const branch of ["kf5", "kf6"]) {
    symlinkSync(
      // this is what's written into the symlink, so it's relative to the
      // symlink itself
      path.join("..", "kde-svn", "trunk", `l10n-${branch}`, lang),
      path.join(trunk, branch),
    );
    symlinkSync(
      // prettier-ignore
      path.join("..", "kde-svn", "branches", "stable", `l10n-${branch}`, lang),
      path.join(stable, branch),
    );
  }
}

/**
 * Create the Lokalize project file for `lang`.
 * Assumes we are in the main dir.
 */
function initLokalizeProject(lang?: string, reference?: string) {
  function promptLoop(message: string) {
    while (true) {
      const answer = prompt(message);
      if (typeof answer === "string") return answer;
      console.log("Please provide an answer");
    }
  }
  const targetLang =
    lang ?? promptLoop("Primary language (for Lokalize project):");
  const referenceLang =
    reference ?? promptLoop(`Reference language for ${targetLang}:`);

  const mailingList =
    targetLang === "zh_TW"
      ? "zh-l10n@lists.slat.org"
      : promptLoop(`Mailing list for ${targetLang}:`);
  const languageName =
    targetLang === "zh_TW" ? "Traditional Chinese" : getTeamnames()[targetLang];

  const trunkAlt = referenceLang;
  const stableAlt = `stable.${referenceLang}`;
  const trunkTarget = targetLang;
  const stableTarget = `stable.${targetLang}`;

  mkdirSync(trunkTarget, { recursive: true });
  writeFileSync(
    path.join(trunkTarget, "index.lokalize"),
    `
[General]
AltDir=../${trunkAlt}
BranchDir=../${stableTarget}
LangCode=${targetLang}
LanguageSource=Project
PotBaseDir=../templates
PotBranchDir=../stable.templates
MailingList=${mailingList}
ProjLangTeam=${languageName} <${mailingList}>
ProjectID=kde-translation-${targetLang}
TargetLangCode=${targetLang}
[RegExps]
Markup=(<[^>]+>)+|(&[A-Za-z_:][A-Za-z0-9_\\\\.:-]*;|%[0-9n])+
`.trim(),
  );
  mkdirSync(stableTarget, { recursive: true });
  writeFileSync(
    path.join(stableTarget, "index.lokalize"),
    `
[General]
AltDir=../${stableAlt}
BranchDir=../${trunkTarget}
LangCode=${targetLang}
LanguageSource=Project
PotBaseDir=../stable.templates
PotBranchDir=../templates
MailingList=${mailingList}
ProjLangTeam=${languageName} <${mailingList}>
ProjectID=kde-translation-${targetLang}
TargetLangCode=${targetLang}
[RegExps]
Markup=(<[^>]+>)+|(&[A-Za-z_:][A-Za-z0-9_\\\\.:-]*;|%[0-9n])+
`.trim(),
  );
}

program
  .command("init")
  .description("Initialize a translation workspace")
  .argument(
    "[dir]",
    "Where to clone to, defaults to 'kde-translations'",
    "kde-translations",
  )
  .option(
    "--langs <languages>",
    "Which languages to clone, as language codes. Comma-separated.",
  )
  .option("--read-only", "the --limit argument of svn log")
  .action(async (dir: string, opts: { langs?: string; readOnly?: boolean }) => {
    const languages = opts?.langs
      ? opts.langs.split(",").map((x) => x.trim())
      : [];
    if (languages.length < 1) {
      console.log(`Please specify one or more languages with --langs`);
      process.exit(1);
    }
    if (existsSync(dir)) {
      console.log(`${dir} already exists.`);
      process.exit(1);
    }
    // kde-translations/kde-svn
    await setupSvnCheckout(path.join(dir, "kde-svn"), opts.readOnly, languages);
    // kde-translations/l10n-templates
    const $$ = $({ verbose: true });
    await $$`git clone --depth 1 https://invent.kde.org/localization/l10n-templates`;

    console.log("Creating Lokalize project structure...");
    for (const lang of languages) {
      setupLanguageSymlinks(lang);
    }

    console.log("Setting up templates...");
    // kde-translations/{"","stable."}templates/{kf5,kf6}
    mkdirSync("stable.templates");
    // again, these symlink targets are relative to the symlink itself
    symlinkSync(
      path.join("..", "l10n-templates", "stable5"),
      path.join("stable.templates", "kf5"),
    );
    symlinkSync(
      path.join("..", "l10n-templates", "stable6"),
      path.join("stable.templates", "kf6"),
    );
    mkdirSync("templates");
    symlinkSync(
      path.join("..", "l10n-templates", "trunk5"),
      path.join("templates", "kf5"),
    );
    symlinkSync(
      path.join("..", "l10n-templates", "trunk6"),
      path.join("templates", "kf6"),
    );

    console.log("Setting up Lokalize project...");
    initLokalizeProject();

    console.log(`Checkout done.
The Lokalize project can be seen in ${dir}/<language>/index.lokalize.
The filled-in metadata most likely needs updating.
Use ${chalk.yellow("k-kdesvn update")} at ${dir} to do an svn update followed by adding the new changes into one local git commit, as well as updating the templates repository.`);
  });

program
  .command("no-docmessages")
  .description("Change the current workspace to not include docmessages")
  .action(async () => {
    const abs = process.cwd();
    const $$ = $({ verbose: true });
    cd("kde-svn");
    await $$`fd docmessages -j 1 -x svn update --set-depth empty`;
    await $$`git add .`;
    await $$`git commit -m "don't keep track of docmessages"`;
    cd(abs);
    cd("l10n-templates");
    await $$`
      git sparse-checkout set ${[
        "stable5",
        "stable6",
        "summit",
        "trunk5",
        "trunk6",
      ].map((p) => path.join(p, "messages"))}
    `;
  });

program
  .command("checkout-language")
  .description("Add a language to the workspace")
  .argument(
    "[dir]",
    "Where the workspace is, defaults to '~/kde-translations'",
    path.join(homedir(), "kde-translations"),
  )
  .option("--lang <language>", "Which language to clone, as a language code.")
  .action(async (dir: string, opts: { lang?: string }) => {
    // only support one since we also need to initialize the project
    if (!opts.lang) {
      console.log(`Please specify the language with --lang`);
      process.exit(1);
    }
    cd(path.resolve(path.join(dir, "kde-svn")));
    await checkoutLanguages([opts.lang]);
    cd(path.resolve(path.join(dir)));
    setupLanguageSymlinks(opts.lang);
    initLokalizeProject(opts.lang);
  });

program
  .command("check")
  .description("Do an msgfmt check for all po files")
  .action(async () => {
    const $$ = $({ nothrow: true, verbose: true });
    await $$`fd -e po -x msgfmt -o /dev/null --check-format`;
    await $$`posieve check-tp-kde .`;
  });

program
  .command("update")
  .description(
    `Pull new changes from upstream to the workspace.
This updates both the svn repository and the templates Git repository.

Run this in the top level of the workspace itself, ie. the directory that includes ./kde-svn and ./l10n-templates.
`,
  )
  .argument(
    "[dir]",
    "Where the workspace is, defaults to '~/kde-translations'",
    path.join(homedir(), "kde-translations"),
  )
  .action(async (dir: string) => {
    const $$ = $({ verbose: true });
    try {
      const abs = path.resolve(dir);
      await $$`cd ${path.join(abs, "kde-svn")} && svn update && git add . && git commit -m before`;
      await $$`cd ${path.join(abs, "l10n-templates")} && git pull`;
    } catch (_e) {
      // do nothing, the commands already explain what went wrong
    }
  });

program
  .command("msg")
  .summary("Copy latest Git commit message into the clipboard.")
  .description(
    `Copy latest Git commit message into the clipboard.
Assumes xsel is installed and working.
`,
